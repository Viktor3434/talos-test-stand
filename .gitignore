# ============================================================
# Talos / Kubernetes (секреты и временные конфигурации)
# ============================================================
# secrets.yaml – никогда не коммитить, даже в закрытый репозиторий
secrets.yaml
*.kubeconfig
# talosconfig лучше держать локально, но можно добавить если хотите
# talosconfig

# Файл с параметрами кластера (генерируется автоматически)
.cluster_params.json

# ============================================================
